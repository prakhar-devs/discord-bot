# Discord Bot Token (required)
# Get from: https://discord.com/developers/applications → Bot → Token
BOT_TOKEN=your-discord-bot-token-here

# Reddit Cookie (optional, needed for NSFW posts)
# How to get:
#   1. Open https://www.reddit.com in your browser
#   2. Log in to your Reddit account
#   3. Open DevTools (F12) → Network tab
#   4. Refresh the page
#   5. Click any request to reddit.com
#   6. Find "Cookie" in Request Headers
#   7. Copy the entire cookie string and paste below
REDDIT_COOKIE=your-reddit-cookie-here
